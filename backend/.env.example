NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Next.js origin — OAuth redirects, invite links (no trailing slash)
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
ENABLE_RESPONSE_ENVELOPE=true
ENVELOPE_LEGACY_FIELDS=true
API_VERSION_DEFAULT=v1

# Redis (queues / SSE pub-sub / idempotency) — define REDIS_URL only once; last duplicate wins
# Production: REDIS_URL required when REQUIRE_REDIS=true (default)
REQUIRE_REDIS=true
# Local
REDIS_URL=redis://localhost:6379
# Remote with password in URL (redis:// or TLS rediss://)
# REDIS_URL=redis://default:YOUR_PASSWORD@your-redis-host:6379/0
# REDIS_URL=rediss://default:YOUR_PASSWORD@your-redis-host:6380/0
# Or password via env when omitted from URL
# REDIS_PASSWORD=YOUR_PASSWORD
# REDIS_TLS=true

# App entry (Docker): api | worker | scheduler | combined
APP_ENTRY=combined
RUN_MIGRATIONS=false
MESSAGE_SEND_ASYNC=true

# Storage (S3-compatible — MinIO for local dev)
STORAGE_PROVIDER=minio
STORAGE_BUCKET=uploads
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minio
STORAGE_SECRET_ACCESS_KEY=minio123
STORAGE_PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE_MB=25

# Search
SEARCH_PROVIDER=postgres
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
OPENSEARCH_URL=

# Observability
LOG_LEVEL=info
THROTTLE_LIMIT=120
BULL_BOARD_ENABLED=false
SCHEDULER_CALENDAR_SYNC_ENABLED=false
VIRUS_SCAN_ENABLED=false

# Retention (scheduler enqueues cleanup jobs — requires worker + scheduler processes)
WEBHOOK_EVENT_RETENTION_DAYS=30
ASYNC_JOB_RETENTION_DAYS=90
ORPHAN_FILE_PENDING_HOURS=24

# Optional: export OpenAPI spec to openapi.json on boot
# WRITE_OPENAPI=true
ENVELOPE_LEGACY_FIELDS=true

# Async messaging (default: queue-backed send)
MESSAGE_SEND_ASYNC=true

# Object storage (S3-compatible — MinIO for local dev)
STORAGE_PROVIDER=minio
STORAGE_BUCKET=app-uploads
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE_MB=25

# Search (Sprint 1: postgres only)
SEARCH_PROVIDER=postgres

# Docker runtime: api | worker | scheduler | combined
APP_ENTRY=combined
RUN_MIGRATIONS=false

# Database — option 1: separate vars (recommended)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=app_db

# Database — option 2: template (expanded at startup; requires DB_* vars above)
DATABASE_URL="postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}?schema=public"

# Database — option 3: full URL only (no DB_* needed)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/app_db?schema=public

# JWT (use strong random secrets in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Seed (development)
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!

# Google OAuth (business integrations)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/google/callback
INTEGRATION_ENCRYPTION_KEY=change-me-integration-encryption-key-32chars
# Optional: user id for webhook/system audit logs (defaults to first platform super admin)
# SYSTEM_AUDIT_ACTOR_USER_ID=

# Meta (WhatsApp, Facebook Pages, Instagram) — platform config via env only (not Platform UI)
META_OAUTH_ENABLED=true
META_APP_ID=
META_APP_SECRET=
# Register this exact URL in the Meta app (Facebook Login > Valid OAuth Redirect URIs).
# The callback routes WhatsApp vs Facebook/Instagram using signed OAuth state.
META_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/meta/callback
#
# Meta dashboard: create separate Login for Business / Embedded Signup configurations.
#
# A) Facebook — Login for Business, variation: Facebook / Pages / general business login
#    Permissions: public_profile, email, pages_show_list, pages_read_engagement,
#    pages_manage_metadata, pages_messaging
META_FACEBOOK_LOGIN_CONFIG_ID=
#
# B) Instagram — Instagram API with Facebook Login (NOT Instagram Business Login)
#    Meta dashboard: Instagram product → API setup with Facebook login →
#    Set up Facebook Login for Business → copy configuration ID here.
#    OAuth must use www.facebook.com/.../dialog/oauth (this app enforces that).
#    Do NOT use Instagram Business Login / Get Started / direct Instagram login IDs.
#    Permissions: email, pages_show_list, pages_read_engagement, pages_manage_metadata,
#    instagram_basic, instagram_manage_messages
META_INSTAGRAM_LOGIN_CONFIG_ID=
# Set true to log OAuth host, redirect_uri, and sync counts (no tokens)
# META_OAUTH_DEBUG=true
#
# C) Deprecated fallback — used only when provider-specific ID above is unset
META_LOGIN_CONFIG_ID=
#
# D) WhatsApp — Embedded Signup configuration (not Login for Business)
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Optional: separate WhatsApp embedded signup redirect if registered in Meta app
# META_WHATSAPP_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/meta/whatsapp/callback
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v20.0

# LinkedIn OAuth (business integrations)
LINKEDIN_OAUTH_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/linkedin/callback
# LinkedIn API version header (YYYYMM) for future LinkedIn REST calls
LINKEDIN_API_VERSION=202506

# Stripe Connect (business integrations — per-business connected accounts)
STRIPE_CONNECT_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/stripe/callback
STRIPE_WEBHOOK_SECRET_PLATFORM=
STRIPE_WEBHOOK_SECRET_CONNECTED_ACCOUNT=
STRIPE_API_VERSION=2025-05-28.basil
