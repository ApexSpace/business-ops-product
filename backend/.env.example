NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Next.js origin — OAuth redirects, invite links (no trailing slash)
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
ENABLE_RESPONSE_ENVELOPE=true

# Database — option 1: separate vars (recommended)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=app_db

# Database — option 2: template (expanded at startup; requires DB_* vars above)
DATABASE_URL="postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}?schema=public"

# Database — option 3: full URL only (no DB_* needed)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/app_db?schema=public

# JWT (use strong random secrets in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Seed (development)
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!

# Google OAuth (business integrations)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/google/callback
INTEGRATION_ENCRYPTION_KEY=change-me-integration-encryption-key-32chars

# Meta (WhatsApp, Facebook Pages, Instagram) — platform config via env only (not Platform UI)
META_OAUTH_ENABLED=true
META_APP_ID=
META_APP_SECRET=
# Register this exact URL in the Meta app (Facebook Login > Valid OAuth Redirect URIs).
# The callback routes WhatsApp vs Facebook/Instagram using signed OAuth state.
META_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/meta/callback
# Facebook Login for Business configuration ID — Facebook & Instagram connect only
META_LOGIN_CONFIG_ID=
# WhatsApp Embedded Signup configuration ID — WhatsApp connect only
META_EMBEDDED_SIGNUP_CONFIG_ID=
# Optional: separate WhatsApp embedded signup redirect if registered in Meta app
# META_WHATSAPP_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/meta/whatsapp/callback
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v20.0

# LinkedIn OAuth (business integrations)
LINKEDIN_OAUTH_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/linkedin/callback
# LinkedIn API version header (YYYYMM) for future LinkedIn REST calls
LINKEDIN_API_VERSION=202506
