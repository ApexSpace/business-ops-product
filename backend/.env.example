# =============================================================================
# Redis (queues, webhooks, realtime SSE, idempotency)
# =============================================================================

# Local Docker: npm run redis:up  →  redis://127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379
# DB_POOL_MAX=20

# =============================================================================
# Transactional email (Resend) — see libs/core/config/email/email-env.validation.ts
# =============================================================================

# Master switch. When false, email sending and webhook processing are skipped.
EMAIL_ENABLED=false

# Required when EMAIL_ENABLED=true. Format: "Display Name <address@domain.com>"
EMAIL_DEFAULT_FROM=

# Optional reply-to address
EMAIL_DEFAULT_REPLY_TO=

# Required when EMAIL_ENABLED=true
RESEND_API_KEY=

# Svix signing secret from Resend webhook settings.
# Optional when EMAIL_ENABLED=false.
# Required in production when exposing POST /webhooks/resend (signature verification).
RESEND_WEBHOOK_SECRET=

# BullMQ email queue tuning (requires REDIS_URL when EMAIL_ENABLED=true)
EMAIL_QUEUE_CONCURRENCY=10
EMAIL_JOB_ATTEMPTS=5
EMAIL_JOB_BACKOFF_MS=2000

# Public app URL used in invoice, invite, booking, and auth email links.
# FRONTEND_URL=http://localhost:3001
