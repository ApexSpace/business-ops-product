model PlanTierCapability {
  id           String   @id @default(uuid())
  planTierId   String
  capabilityId String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  planTier   PlanTier   @relation(fields: [planTierId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([planTierId, capabilityId])
  @@index([planTierId, sortOrder])
  @@map("plan_tier_capabilities")
}

model PlanTierFeature {
  id          String   @id @default(uuid())
  planTierId  String
