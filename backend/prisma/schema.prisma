generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum PlatformMemberRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  SUPPORT
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum AuthContextType {
  platform
  business
}

enum IndustryStatus {
  ACTIVE
  ARCHIVED
}

enum PipelineStageType {
  OPEN
  WON
  LOST
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

enum ServiceStatus {
  ACTIVE
  ARCHIVED
}

enum PlanStatus {
  ACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  platformMembership   PlatformMembership?
  businessMemberships  BusinessMembership[]
  createdBusinesses    Business[]            @relation("BusinessCreatedBy")
  auditLogs            AuditLog[]            @relation("AuditActor")
  refreshTokens        RefreshToken[]
  invitedMemberships   BusinessMembership[]  @relation("MembershipInvitedBy")
  createdContacts      Contact[]             @relation("ContactCreatedBy")
  assignedLeads        Lead[]                @relation("LeadAssignedTo")
  createdLeads         Lead[]                @relation("LeadCreatedBy")

  @@map("users")
}

model PlatformMembership {
  id        String             @id @default(uuid())
  userId    String             @unique
  role      PlatformMemberRole
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_memberships")
}

model Industry {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  description      String?
  labels           Json
  pipelineTemplate Json
  status           IndustryStatus @default(ACTIVE)
  sortOrder        Int            @default(0)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  businesses Business[]

  @@map("industries")
}

model Business {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  industryId       String?
  status           BusinessStatus @default(ACTIVE)
  firstName        String?
  lastName         String?
  displayName      String?
  email            String?
  phoneCountryCode String?
  phoneNumber      String?
  address          String?
  city             String?
  state            String?
  country          String?
  zip              String?
  website          String?
  timezone         String?
  settings         Json?
  createdById      String?
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  createdBy      User?             @relation("BusinessCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  industry       Industry?         @relation(fields: [industryId], references: [id], onDelete: SetNull)
  memberships    BusinessMembership[]
  subscription   BusinessSubscription?
  auditLogs      AuditLog[]
  contacts       Contact[]
  tags           Tag[]
  pipelines      Pipeline[]
  pipelineStages PipelineStage[]
  leads          Lead[]
  services       Service[]

  @@index([createdById])
  @@index([industryId])
  @@map("businesses")
}

model BusinessMembership {
  id          String             @id @default(uuid())
  userId      String
  businessId  String
  role        BusinessMemberRole
  status      MembershipStatus   @default(INVITED)
  invitedById String?
  inviteToken String?            @unique
  joinedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User?    @relation("MembershipInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
  @@map("business_memberships")
}

model RefreshToken {
  id          String           @id @default(uuid())
  userId      String
  tokenHash   String           @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  deletedAt   DateTime?
  contextType AuthContextType?
  businessId  String?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String
  businessId   String?
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime @default(now())

  actor    User      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Contact {
  id               String    @id @default(uuid())
  businessId       String
  firstName        String?
  lastName         String?
  displayName      String?
  companyName      String?
  email            String?
  phoneCountryCode String?
  phoneNumber      String?
  timezone         String?
  address          String?
  city             String?
  state            String?
  country          String?
  zip              String?
  avatarUrl        String?
  source           String?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  business  Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tags      ContactTag[]
  leads     Lead[]

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([businessId, email])
  @@index([businessId, phoneNumber])
  @@map("contacts")
}

model Tag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  createdAt  DateTime @default(now())

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Pipeline {
  id         String   @id @default(uuid())
  businessId String
  name       String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stages   PipelineStage[]
  leads    Lead[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("pipelines")
}

model PipelineStage {
  id         String             @id @default(uuid())
  businessId String
  pipelineId String
  name       String
  position   Int
  type       PipelineStageType?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@unique([pipelineId, position])
  @@index([businessId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Service {
  id          String        @id @default(uuid())
  businessId  String
  name        String
  category    String?
  description String?
  price       Decimal?      @db.Decimal(12, 2)
  status      ServiceStatus @default(ACTIVE)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@index([businessId])
  @@map("services")
}

model Lead {
  id              String     @id @default(uuid())
  businessId      String
  contactId       String?
  serviceId       String?
  pipelineId      String
  pipelineStageId String
  assignedToId    String?
  title           String?
  value           Decimal?   @db.Decimal(12, 2)
  status          LeadStatus @default(ACTIVE)
  source          String?
  notes           String?
  createdById     String?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineStage PipelineStage @relation(fields: [pipelineStageId], references: [id], onDelete: Restrict)
  assignedTo    User?         @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([businessId, contactId])
  @@index([businessId])
  @@index([businessId, pipelineId])
  @@index([businessId, pipelineStageId])
  @@index([businessId, assignedToId])
  @@index([businessId, serviceId])
  @@map("leads")
}

model Plan {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  description  String?
  priceMonthly Decimal    @db.Decimal(10, 2)
  priceYearly  Decimal?   @db.Decimal(10, 2)
  features     Json?
  status       PlanStatus @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  subscriptions BusinessSubscription[]

  @@map("plans")
}

model BusinessSubscription {
  id               String             @id @default(uuid())
  businessId       String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime?
  canceledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([status])
  @@map("business_subscriptions")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
