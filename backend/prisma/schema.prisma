}

model CalendarStaff {
  id         String   @id @default(uuid())
  businessId String
  calendarId String
  userId     String
  role       String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarId, userId])
  @@index([businessId])
  @@index([calendarId])
  @@map("calendar_staff")
}

model CalendarAvailability {
  id         String    @id @default(uuid())
  businessId String
  calendarId String
  dayOfWeek  DayOfWeek
  startTime  String
  endTime    String
  isEnabled  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([calendarId, dayOfWeek])
  @@index([businessId])
  @@map("calendar_availability")
}

model CalendarException {
  id            String    @id @default(uuid())
  businessId    String
  calendarId    String
  date          DateTime  @db.Date
  startTime     String?
  endTime       String?
  isUnavailable Boolean   @default(true)
  reason        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([calendarId, date])
  @@map("calendar_exceptions")
}

model Appointment {
  id               String             @id @default(uuid())
  businessId       String
  calendarId       String
  contactId        String
  serviceId        String?
  workItemId       String?
  assignedToId     String?
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime
  status           AppointmentStatus  @default(SCHEDULED)
  source           AppointmentSource  @default(INTERNAL)
  locationType     CalendarLocationType?
  locationValue    String?
  notes            String?
  metadata         Json?
  externalProvider String?
  externalEventId  String?
  createdById      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  calendar   Calendar  @relation(fields: [calendarId], references: [id], onDelete: Restrict)
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Restrict)
  service    Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  workItem   WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("AppointmentAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?     @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, calendarId])
  @@index([businessId, contactId])
  @@index([businessId, startAt])
  @@index([businessId, status])
  @@map("appointments")
}

model Conversation {
  id                     String             @id @default(uuid())
  businessId             String
  contactId              String?
  channel                ConversationChannel
  providerKey            String
  resourceId             String?
  externalConversationId String
  externalParticipantId  String
  externalPageId         String?
  title                  String?
  status                 ConversationStatus @default(OPEN)
  assignedToUserId       String?
  lastMessageAt          DateTime?
  lastMessagePreview     String?
  unreadCount            Int                @default(0)
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  deletedAt              DateTime?

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("ConversationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages   ConversationMessage[]
  participants ConversationParticipant[]

  @@unique([businessId, channel, externalConversationId])
  @@index([businessId])
  @@index([contactId])
  @@index([channel])
  @@index([status])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
  @@index([businessId, lastMessageAt])
  @@map("conversations")
}

model ConversationMessage {
  id                  String                @id @default(uuid())
  businessId          String
  conversationId      String
  contactId           String?
  channel             ConversationChannel
  providerKey         String
  direction           ConversationDirection
  senderType          MessageSenderType
  senderUserId        String?
  externalMessageId   String?
  externalSenderId    String?
  externalRecipientId String?
  text                String?
  attachments         Json?
  status              MessageStatus         @default(RECEIVED)
  errorMessage        String?
  metadata            Json?
  sentAt              DateTime?
  receivedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([businessId, channel, externalMessageId])
  @@index([businessId])
  @@index([conversationId])
  @@index([channel])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model ConversationParticipant {
  id                    String   @id @default(uuid())
  businessId            String
  conversationId        String
  contactId             String?
  externalParticipantId String
  name                  String?
  profilePictureUrl     String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([conversationId, externalParticipantId])
  @@index([businessId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Chatbot {
  id                    String        @id @default(uuid())
  businessId            String
  name                  String
  status                ChatbotStatus @default(DRAFT)
  publicKey             String        @unique
  description           String?
  appearanceSettings    Json          @default("{}")
  chatWindowSettings    Json          @default("{}")
  messagingSettings     Json          @default("{}")
  businessHoursSettings Json          @default("{}")
  formSettings          Json          @default("{}")
  botSettings           Json          @default("{}")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rules    ChatbotRule[]
  sessions ChatbotSession[]

  @@index([businessId])
  @@index([businessId, status])
  @@map("chatbots")
}

model Form {
  id          String     @id @default(uuid())
  businessId  String
  name        String
  slug        String?
  publicKey   String     @unique
  status      FormStatus @default(DRAFT)
  definition  Json       @default("{}")
  metadata    Json?
  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, deletedAt])
  @@map("forms")
}

model FormSubmission {
  id         String   @id @default(uuid())
  businessId String
  formId     String
  publicKey  String
  data       Json
  metadata   Json?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  form     Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([formId])
  @@index([formId, createdAt])
  @@index([publicKey])
  @@map("form_submissions")
}

model ChatbotRule {
  id           String                 @id @default(uuid())
  businessId   String
  chatbotId    String
  triggerType  ChatbotRuleTriggerType
  triggerText  String
  responseText String
  sortOrder    Int                    @default(0)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  chatbot  Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([chatbotId])
  @@index([chatbotId, sortOrder])
  @@map("chatbot_rules")
}

model ChatbotSession {
  id             String               @id @default(uuid())
  businessId     String
  chatbotId      String
  conversationId String?
  contactId      String?
  visitorId      String
  visitorName    String?
  visitorEmail   String?
  visitorPhone   String?
  pageUrl        String?
  referrer       String?
  userAgent      String?
  ipHash         String?
  status         ChatbotSessionStatus @default(ACTIVE)
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  endedAt        DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  chatbot  Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([chatbotId])
  @@index([visitorId])
  @@index([conversationId])
  @@index([contactId])
  @@map("chatbot_sessions")
}

model WebhookEvent {
  id              String               @id @default(uuid())
  provider        WebhookEventProvider
  businessId      String?
  externalEventId String?
  eventType       String
  payload         Json?
  status          WebhookEventStatus   @default(RECEIVED)
  errorMessage    String?
  receivedAt      DateTime             @default(now())
  processedAt     DateTime?

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([provider])
  @@index([businessId])
  @@index([externalEventId])
  @@index([status])
  @@index([receivedAt])
  @@map("webhook_events")
}

model BusinessEmailPreference {
  id         String   @id @default(uuid())
  businessId String
  emailType  String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, emailType])
  @@index([businessId])
  @@map("business_email_preferences")
}

model EmailTemplate {
  id              String   @id @default(uuid())
  businessId      String
  emailType       String
  subject         String
  htmlBody        String   @db.Text
  textBody        String?  @db.Text
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("EmailTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("EmailTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([businessId, emailType])
  @@index([businessId])
  @@map("email_templates")
}

model EmailMessage {
  id                String             @id @default(uuid())
  businessId        String?
  contactId         String?
  userId            String?
  emailType         String
  toEmail           String
  fromEmail         String
  replyTo           String?
  subject           String
  status            EmailMessageStatus @default(QUEUED)
  provider          EmailProvider      @default(RESEND)
  providerMessageId String?
  entityType        String?
  entityId          String?
  metadata          Json?
  errorMessage      String?
  queuedAt          DateTime           @default(now())
  sentAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@index([providerMessageId])
  @@index([businessId, createdAt])
  @@index([businessId, emailType, entityType, entityId])
  @@map("email_messages")
}

model AsyncJob {
  id           String         @id @default(uuid())
  businessId   String
  type         String
  status       AsyncJobStatus   @default(QUEUED)
  entityType   String?
  entityId     String?
  bullJobId    String?
  idempotencyKey String?
  result       Json?
  errorMessage String?
  createdById  String?
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("AsyncJobActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@unique([businessId, idempotencyKey])
  @@map("async_jobs")
}

model FileAsset {
  id           String          @id @default(cuid())
  businessId   String
  business     Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  originalName String
  filename     String
  mimeType     String
  size         Int
  category     FileCategory
  objectKey    String          @unique
  status       FileAssetStatus @default(PENDING)
  visibility   FileVisibility  @default(PRIVATE)
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([businessId])
  @@index([uploadedById])
  @@index([businessId, category])
  @@index([status])
  @@map("file_assets")
}

