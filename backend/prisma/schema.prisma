}

model CapabilityConfigSchema {
  id                String    @id @default(uuid())
  capabilityId      String
  schemaKey         String
  name              String
  description       String?
  schemaJson        Json
  defaultConfigJson Json?
  metadata          Json?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([capabilityId, schemaKey])
  @@index([capabilityId])
  @@map("capability_config_schemas")
}

/// Current commercial and access state for a business (one row per business).
/// Trial window uses currentPeriodStart/currentPeriodEnd — not separate trial columns.
model BusinessSubscription {
  id                 String                    @id @default(uuid())
  businessId         String                    @unique
  planGroupId        String?
  planTierId         String?
  status             SubscriptionStatus        @default(TRIALING)
  paymentMethod      SubscriptionPaymentMethod @default(NOT_SELECTED)
  paymentStatus      SubscriptionPaymentStatus @default(NOT_REQUIRED)
  billingCycle       BusinessSubscriptionBillingCycle?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  amount             Decimal?                  @db.Decimal(10, 2)
  currency           String?
  notes              String?
  metadata           Json?
  canceledAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planGroup PlanGroup? @relation(fields: [planGroupId], references: [id], onDelete: SetNull)
  planTier  PlanTier?  @relation(fields: [planTierId], references: [id], onDelete: SetNull)
  events    BusinessSubscriptionEvent[]
  payments  BusinessSubscriptionPayment[]

  @@index([planGroupId])
  @@index([planTierId])
  @@index([status])
  @@index([paymentStatus])
  @@map("business_subscriptions")
}

/// Immutable audit log of subscription/access changes. JSON fromState/toState snapshots are allowed.
model BusinessSubscriptionEvent {
  id                    String                          @id @default(uuid())
  businessId            String
  subscriptionId        String?
  eventType             BusinessSubscriptionEventType
  title                 String
  description           String?
  fromState             Json?
  toState               Json?
  source                BusinessSubscriptionEventSource @default(ADMIN)
  severity              BusinessSubscriptionEventSeverity @default(INFO)
  correlationId         String
  actionKey             String?
  paymentId             String?
  reason                String?
  notes                 String?
  metadata              Json?
  createdById           String?
  createdByNameSnapshot String?
  createdAt             DateTime                        @default(now())

  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription BusinessSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment      BusinessSubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdBy    User?                 @relation("SubscriptionEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([subscriptionId])
  @@index([eventType])
  @@index([createdAt])
  @@index([correlationId])
  @@index([actionKey])
  @@map("business_subscription_events")
}

/// Per-payment ledger record. Does not duplicate subscription status fields.
model BusinessSubscriptionPayment {
  id                 String                             @id @default(uuid())
  businessId         String
  subscriptionId     String?
  amount             Decimal                            @db.Decimal(10, 2)
  currency           String
  paymentMethod      SubscriptionPaymentMethod
  paymentStatus      SubscriptionPaymentStatus
  paymentType        BusinessSubscriptionPaymentType
  billingCycle       BusinessSubscriptionBillingCycle
  direction          BusinessSubscriptionPaymentDirection @default(INCOMING)
  source             BusinessSubscriptionPaymentSource  @default(ADMIN)
  periodStart        DateTime?
  periodEnd          DateTime?
  dueDate            DateTime?
  paidAt             DateTime?
  recordedAt         DateTime                           @default(now())
  voidedAt           DateTime?
  voidReason         String?
  paymentReference   String?
  notes              String?
  metadata           Json?
  externalProvider   String?
  externalPaymentId  String?
  createdById        String?
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt

  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription BusinessSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdBy    User?                 @relation("SubscriptionPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  events       BusinessSubscriptionEvent[]

  @@index([businessId])
  @@index([subscriptionId])
  @@index([paymentStatus])
  @@index([paymentMethod])
  @@index([paymentType])
  @@index([direction])
  @@index([paidAt])
  @@index([dueDate])
  @@index([recordedAt])
  @@index([voidedAt])
  @@map("business_subscription_payments")
}

model BusinessCapability {
  id           String                             @id @default(uuid())
  businessId   String
  capabilityId String
  source       BusinessCapabilitySource
  status       BusinessCapabilityAssignmentStatus @default(ACTIVE)
  createdAt    DateTime                           @default(now())
  updatedAt    DateTime                           @updatedAt

