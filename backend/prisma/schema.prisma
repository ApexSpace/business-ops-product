}

model PlanTier {
  id           String         @id @default(uuid())
  planGroupId  String
  slug         String
  name         String
  description  String?
  status       PlanTierStatus @default(DRAFT)
  priceMonthly Decimal?       @db.Decimal(10, 2)
  priceYearly  Decimal?       @db.Decimal(10, 2)
  setupFee     Decimal?       @db.Decimal(10, 2)
