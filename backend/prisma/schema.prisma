// Future: snapshot_capability_configs — snapshot-level capability configuration overrides.

model Capability {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  icon        String?
  status      CapabilityStatus @default(DRAFT)
  sortOrder   Int              @default(0)
  metadata    Json?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  modules              CapabilityModule[] // TODO: legacy — superseded by CapabilityModuleAssignment
  moduleAssignments    CapabilityModuleAssignment[]
  features             CapabilityFeature[] // TODO: legacy — superseded by RegistryFeature + CapabilityFeatureAssignment
  featureAssignments   CapabilityFeatureAssignment[]
  permissions          CapabilityPermission[] // TODO: unused in v2 assignment model
  limits               CapabilityLimit[]
  navigationItems      CapabilityNavigationItem[]
  configSchemas        CapabilityConfigSchema[]
  tierAssignments      PlanTierCapability[]
  businessAssignments  BusinessCapability[]

  @@index([status])
  @@index([sortOrder])
  @@map("capabilities")
}

/// Global code-backed feature catalog (many-to-many with admin-created capabilities).
model RegistryFeature {
  id             String                  @id @default(uuid())
  key            String                  @unique
  moduleKey      String
  moduleName     String
  name           String
  description    String?
  permissionKey  String?
  routeKeys      Json?
  icon           String?
  defaultEnabled Boolean                 @default(false)
  status         CapabilityFeatureStatus @default(ACTIVE)
  source         CapabilityFeatureSource @default(CODE)
  isBillable     Boolean                 @default(false)
  limitKey       String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  assignments CapabilityFeatureAssignment[]

  @@index([moduleKey])
  @@index([status])
  @@index([source])
  @@map("registry_features")
}

/// Links an admin-created capability bundle to global registry features.
model CapabilityFeatureAssignment {
  id           String                  @id @default(uuid())
  capabilityId String
  featureKey   String
  status       CapabilityFeatureStatus @default(ACTIVE)
  sortOrder    Int                     @default(0)
  metadata     Json?
  deletedAt    DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  capability Capability      @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  feature    RegistryFeature @relation(fields: [featureKey], references: [key], onDelete: Restrict)

  @@unique([capabilityId, featureKey])
  @@index([capabilityId])
  @@index([featureKey])
  @@map("capability_feature_assignments")
}

/// Links an admin-created capability bundle to platform modules (auto-includes feature keys).
model CapabilityModuleAssignment {
  id           String    @id @default(uuid())
  capabilityId String
  moduleKey    String
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([capabilityId, moduleKey])
  @@index([capabilityId])
  @@index([moduleKey])
  @@map("capability_module_assignments")
}

// TODO: legacy — superseded by CapabilityModuleAssignment + registry module catalog.
model CapabilityModule {
  id           String                 @id @default(uuid())
  capabilityId String
  key          String
  name         String
  description  String?
  status       CapabilityModuleStatus @default(ACTIVE)
  sortOrder    Int                    @default(0)
  metadata     Json?
  deletedAt    DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  capability      Capability                 @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  features        CapabilityFeature[]
  navigationItems CapabilityNavigationItem[]

  @@unique([capabilityId, key])
  @@map("capability_modules")
}

// TODO: legacy — superseded by RegistryFeature + CapabilityFeatureAssignment.
model CapabilityFeature {
  id             String                  @id @default(uuid())
  capabilityId   String
  moduleId       String?
  key            String                  @unique
  name           String
  description    String?
  status         CapabilityFeatureStatus @default(ACTIVE)
  source         CapabilityFeatureSource @default(MANUAL)
  defaultEnabled Boolean                 @default(false)
  isBillable     Boolean                 @default(false)
  permissionKey  String?
  limitKey       String?
  metadata       Json?
  deletedAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  capability  Capability             @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  module      CapabilityModule?      @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  permissions CapabilityPermission[]

  @@index([capabilityId])
  @@index([moduleId])
  @@index([status])
  @@map("capability_features")
}

model CapabilityPermission {
  id           String    @id @default(uuid())
  capabilityId String
  featureId    String?
  key          String    @unique
  name         String
  description  String?
  metadata     Json?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  capability Capability         @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  feature    CapabilityFeature? @relation(fields: [featureId], references: [id], onDelete: SetNull)

  @@index([capabilityId])
  @@index([featureId])
  @@map("capability_permissions")
}

model CapabilityLimit {
  id           String    @id @default(uuid())
  capabilityId String
