generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum PlatformMemberRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  SUPPORT
}

enum BusinessStatus {
  ACTIVE
  NOT_ACTIVE
  SUSPENDED
  /// Legacy/backward-compat — treated as blocked for workspace access (same as NOT_ACTIVE).
  ARCHIVED
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum AuthContextType {
  platform
  business
}

enum IndustryStatus {
  ACTIVE
  ARCHIVED
}

enum SnapshotStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PipelineStageType {
  OPEN
  WON
  LOST
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
  ARCHIVED
}

enum ServiceStatus {
  ACTIVE
  ARCHIVED
}

enum WorkItemStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum PlanGroupStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PlanTierStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PlanEmbedTheme {
  LIGHT
  DARK
  AUTO
}

enum PlanEmbedLayout {
  CARDS
  COMPARISON
}

enum CapabilityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  DEPRECATED
}

enum CapabilityModuleStatus {
  ACTIVE
  INACTIVE
}

enum CapabilityFeatureStatus {
  INTERNAL
  BETA
  ACTIVE
  DISABLED
  DEPRECATED
}

enum CapabilityFeatureSource {
  CODE
  MANUAL
}

enum CapabilityNavigationStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PENDING_PAYMENT
  CANCELED
  EXPIRED
  INTERNAL
  /// Legacy/backward-compat — treated as blocked; prefer PENDING_PAYMENT for new records.
  PAST_DUE
}

enum SubscriptionPaymentMethod {
  STRIPE
  BANK_TRANSFER
  WISE
  PAYPAL
  CASH
  JAZZCASH
  EASYPAISA
  MANUAL_INVOICE
  FREE_INTERNAL
  NOT_SELECTED
}

enum SubscriptionPaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_PAID
  OVERDUE
}

enum BusinessSubscriptionEventType {
  CREATED
  STATUS_CHANGED
  PLAN_CHANGED
  UPGRADED
  DOWNGRADED
  TRIAL_STARTED
  TRIAL_EXTENDED
  TRIAL_EXPIRED
  PAYMENT_MARKED_PAID
  PAYMENT_PENDING
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  PARTIAL_PAYMENT_RECORDED
  CANCELED
  EXPIRED
  REACTIVATED
  SUSPENDED
  BUSINESS_STATUS_CHANGED
  CAPABILITIES_SYNCED
  SNAPSHOT_CHANGED
  MANUAL_ADJUSTMENT
}

enum BusinessSubscriptionEventSource {
  ADMIN
  SYSTEM
  PUBLIC_SIGNUP
  WEBHOOK
  IMPORT
}

enum BusinessSubscriptionEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum BusinessSubscriptionPaymentType {
  SUBSCRIPTION
  SETUP_FEE
  TRIAL_CONVERSION
  UPGRADE_PRORATION
  REFUND
  CREDIT
  ADJUSTMENT
  MANUAL_PAYMENT
}

enum BusinessSubscriptionPaymentDirection {
  INCOMING
  OUTGOING
}

enum BusinessSubscriptionPaymentSource {
  ADMIN
  SYSTEM
  PUBLIC_SIGNUP
  WEBHOOK
  IMPORT
}

enum BusinessSubscriptionBillingCycle {
  MONTHLY
  YEARLY
  ONE_TIME
  CUSTOM
}

enum BusinessCapabilitySource {
  PLAN_TIER
  CUSTOM
  MANUAL
}

enum BusinessCapabilityAssignmentStatus {
  ACTIVE
  DISABLED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  STRIPE
  OTHER
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERPAID
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
}

enum IntegrationStatus {
  CONNECTED
  ERROR
  DISABLED
  EXPIRED
}

enum IntegrationCategory {
  COMMUNICATION
  CALENDAR
  REPUTATION
  PAYMENTS
  SOCIAL_MEDIA
  ACCOUNTING
  AI
  STORAGE
  ADS
  OTHER
}

enum IntegrationConnectionType {
  MANUAL
  OAUTH
  EMBEDDED_SIGNUP
}

enum IntegrationResourceStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum IntegrationResourceType {
  CALENDAR
  GBP_LOCATION
  FACEBOOK_PAGE
  INSTAGRAM_ACCOUNT
  GOOGLE_ADS_ACCOUNT
  QUICKBOOKS_COMPANY
  XERO_TENANT
  EMAIL_ACCOUNT
  PHONE_NUMBER
  STRIPE_ACCOUNT
  OTHER
}

enum CalendarStatus {
  ACTIVE
  INACTIVE
}

enum CalendarType {
  SERVICE
  STAFF
  ROUND_ROBIN
  COLLECTIVE
  CLASS_EVENT
  PERSONAL
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  INTERNAL
  BOOKING_WIDGET
  PUBLIC_LINK
  GOOGLE_SYNC
  IMPORTED
}

enum CalendarLocationType {
  PHYSICAL
  PHONE_CALL
  GOOGLE_MEET
  ZOOM
  CUSTOM
  ONSITE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ConversationChannel {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  EMAIL
  SMS
  WEBCHAT
  LINKEDIN
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
  SPAM
}

enum ConversationDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  RECEIVED
  SENT
  DELIVERED
  READ
  FAILED
}

enum AsyncJobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
}

enum FileAssetStatus {
  PENDING
  READY
  FAILED
  DELETED
}

enum FileVisibility {
  PRIVATE
  PUBLIC
  SIGNED
}

enum FileCategory {
  IMAGE
  PDF
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

enum MessageSenderType {
  CONTACT
  USER
  SYSTEM
  AI_AGENT
}

enum ChatbotStatus {
  DRAFT
  ACTIVE
  DISABLED
  ARCHIVED
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ChatbotWidgetPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
}

enum ChatbotRuleTriggerType {
  EXACT_MATCH
  CONTAINS
  STARTS_WITH
  FALLBACK
}

enum ChatbotSessionStatus {
  ACTIVE
  ENDED
  CONVERTED
}

enum WebhookEventProvider {
  META
  STRIPE
  GOOGLE
  OTHER
  RESEND
}

enum EmailProvider {
  RESEND
}

enum EmailMessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  BOUNCED
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  platformMembership   PlatformMembership?
  businessMemberships  BusinessMembership[]
  createdBusinesses    Business[]            @relation("BusinessCreatedBy")
  auditLogs            AuditLog[]            @relation("AuditActor")
  refreshTokens        RefreshToken[]
  invitedMemberships   BusinessMembership[]  @relation("MembershipInvitedBy")
  createdContacts      Contact[]             @relation("ContactCreatedBy")
  assignedLeads        Lead[]                @relation("LeadAssignedTo")
  createdLeads         Lead[]                @relation("LeadCreatedBy")
  assignedWorkItems    WorkItem[]            @relation("WorkItemAssignedTo")
  createdWorkItems     WorkItem[]            @relation("WorkItemCreatedBy")
  createdNotes         Note[]                @relation("NoteCreatedBy")
  assignedTasks        Task[]                @relation("TaskAssignedTo")
  createdTasks         Task[]                @relation("TaskCreatedBy")
  createdEstimates     Estimate[]            @relation("EstimateCreatedBy")
  createdInvoices      Invoice[]             @relation("InvoiceCreatedBy")
  createdPayments      Payment[]             @relation("PaymentCreatedBy")
  calendarStaff        CalendarStaff[]
  assignedAppointments Appointment[]         @relation("AppointmentAssignedTo")
  createdCalendars     Calendar[]            @relation("CalendarCreatedBy")
  createdAppointments  Appointment[]         @relation("AppointmentCreatedBy")
  assignedConversations Conversation[]       @relation("ConversationAssignedTo")
  uploadedFileAssets    FileAsset[]
  asyncJobs             AsyncJob[]             @relation("AsyncJobActor")
  emailTemplatesCreated EmailTemplate[]        @relation("EmailTemplateCreatedBy")
  emailTemplatesUpdated EmailTemplate[]        @relation("EmailTemplateUpdatedBy")
  snapshotsCreated      Snapshot[]              @relation("SnapshotCreatedBy")
  snapshotsUpdated      Snapshot[]              @relation("SnapshotUpdatedBy")
  subscriptionEventsCreated BusinessSubscriptionEvent[] @relation("SubscriptionEventCreatedBy")
  subscriptionPaymentsCreated BusinessSubscriptionPayment[] @relation("SubscriptionPaymentCreatedBy")

  @@map("users")
}

model PlatformMembership {
  id        String             @id @default(uuid())
  userId    String             @unique
  role      PlatformMemberRole
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_memberships")
}

model Industry {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  description      String?
  labels           Json
  pipelineTemplate Json
  status           IndustryStatus @default(ACTIVE)
  sortOrder        Int            @default(0)
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  businesses Business[]

  @@map("industries")
}

model Snapshot {
  id              String         @id @default(uuid())
  name            String
  description     String?
  status          SnapshotStatus @default(DRAFT)
  assets          Json
  publishedAt     DateTime?
  createdByUserId String?
  updatedByUserId String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy User? @relation("SnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User? @relation("SnapshotUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  businesses  Business[]
  provisions  SnapshotProvision[]
  planGroups  PlanGroup[]

  @@map("snapshots")
}

model SnapshotProvision {
  id         String   @id @default(uuid())
  businessId String
  snapshotId String
  assetType  String
  sourceKey  String
  entityId   String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([businessId, snapshotId, sourceKey])
  @@index([businessId])
  @@map("snapshot_provisions")
}

model Business {
  id               String         @id @default(uuid())
  name             String
  industryId       String?
  snapshotId       String?
  snapshotAppliedAt DateTime?
  status           BusinessStatus @default(ACTIVE)
  firstName        String?
  lastName         String?
  displayName      String?
  email            String?
  phoneCountryCode String?
  phoneNumber      String?
  address          String?
  city             String?
  state            String?
  country          String?
  zip              String?
  website          String?
  timezone         String?
  settings         Json?
  createdById      String?
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  createdBy      User?             @relation("BusinessCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  industry       Industry?         @relation(fields: [industryId], references: [id], onDelete: SetNull)
  snapshot       Snapshot?         @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  snapshotProvisions SnapshotProvision[]
  memberships    BusinessMembership[]
  subscription        BusinessSubscription?
  subscriptionEvents  BusinessSubscriptionEvent[]
  subscriptionPayments BusinessSubscriptionPayment[]
  auditLogs      AuditLog[]
  contacts       Contact[]
  tags           Tag[]
  pipelines      Pipeline[]
  pipelineStages PipelineStage[]
  leads          Lead[]
  services       Service[]
  workItems      WorkItem[]
  notes          Note[]
  tasks          Task[]
  estimates            Estimate[]
  invoices             Invoice[]
  payments             Payment[]
  businessIntegrations BusinessIntegration[]
  integrationResources IntegrationResource[]
  calendars            Calendar[]
  calendarStaff        CalendarStaff[]
  calendarAvailability CalendarAvailability[]
  calendarExceptions   CalendarException[]
  appointments         Appointment[]
  conversations        Conversation[]
  conversationMessages ConversationMessage[]
  conversationParticipants ConversationParticipant[]
  chatbots             Chatbot[]
  forms                Form[]
  formSubmissions      FormSubmission[]
  chatbotRules         ChatbotRule[]
  chatbotSessions      ChatbotSession[]
  webhookEvents            WebhookEvent[]
  asyncJobs                AsyncJob[]
  fileAssets               FileAsset[]
  businessEmailPreferences BusinessEmailPreference[]
  emailTemplates           EmailTemplate[]
  emailMessages            EmailMessage[]
  capabilities             BusinessCapability[]

  @@index([createdById])
  @@index([industryId])
  @@index([snapshotId])
  @@map("businesses")
}

model BusinessMembership {
  id          String             @id @default(uuid())
  userId      String
  businessId  String
  role        BusinessMemberRole
  status      MembershipStatus   @default(INVITED)
  invitedById String?
  inviteToken String?            @unique
  joinedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User?    @relation("MembershipInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
  @@map("business_memberships")
}

model RefreshToken {
  id          String           @id @default(uuid())
  userId      String
  tokenHash   String           @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  deletedAt   DateTime?
  contextType AuthContextType?
  businessId  String?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String
  businessId   String?
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime @default(now())

  actor    User      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Contact {
  id               String    @id @default(uuid())
  businessId       String
  firstName        String?
  lastName         String?
  displayName      String?
  companyName      String?
  email            String?
  phoneCountryCode String?
  phoneNumber      String?
  timezone         String?
  address          String?
  city             String?
  state            String?
  country          String?
  zip              String?
  avatarUrl        String?
  source           String?
  metadata         Json?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  business  Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tags      ContactTag[]
  leads     Lead[]
  workItems WorkItem[]
  notes     Note[]
  tasks     Task[]
  estimates    Estimate[]
  invoices     Invoice[]
  payments     Payment[]
  appointments Appointment[]
  conversations Conversation[]
  conversationMessages ConversationMessage[]
  conversationParticipants ConversationParticipant[]
  emailMessages EmailMessage[]

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([businessId, email])
  @@index([businessId, phoneNumber])
  @@map("contacts")
}

model Tag {
  id         String   @id @default(uuid())
  businessId String
  name       String
  color      String?
  createdAt  DateTime @default(now())

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Pipeline {
  id         String   @id @default(uuid())
  businessId String
  name       String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stages   PipelineStage[]
  leads    Lead[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("pipelines")
}

model PipelineStage {
  id         String             @id @default(uuid())
  businessId String
  pipelineId String
  name       String
  position   Int
  type       PipelineStageType?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@unique([pipelineId, position])
  @@index([businessId])
  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Service {
  id          String        @id @default(uuid())
  businessId  String
  name        String
  category    String?
  description String?
  price       Decimal?      @db.Decimal(12, 2)
  status      ServiceStatus @default(ACTIVE)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leads         Lead[]
  workItems     WorkItem[]
  estimateItems EstimateItem[]
  invoiceItems  InvoiceItem[]
  appointments  Appointment[]

  @@index([businessId])
  @@map("services")
}

model Lead {
  id              String     @id @default(uuid())
  businessId      String
  contactId       String?
  serviceId       String?
  pipelineId      String
  pipelineStageId String
  assignedToId    String?
  title           String?
  value           Decimal?   @db.Decimal(12, 2)
  status          LeadStatus @default(ACTIVE)
  source          String?
  notes           String?
  createdById     String?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineStage PipelineStage @relation(fields: [pipelineStageId], references: [id], onDelete: Restrict)
  assignedTo    User?         @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([businessId, contactId])
  @@index([businessId])
  @@index([businessId, pipelineId])
  @@index([businessId, pipelineStageId])
  @@index([businessId, assignedToId])
  workItems   WorkItem[]
  linkedNotes Note[] @relation("LeadNotes")
  linkedTasks Task[] @relation("LeadTasks")

  @@index([businessId, serviceId])
  @@map("leads")
}

model Note {
  id              String    @id @default(uuid())
  businessId      String
  contactId       String?
  leadId          String?
  title           String
  description     String    @default("")
  descriptionText String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead      Lead?    @relation("LeadNotes", fields: [leadId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, leadId])
  @@index([businessId, createdAt])
  @@map("notes")
}

model Task {
  id              String        @id @default(uuid())
  businessId      String
  contactId       String?
  leadId          String?
  title           String
  description     String        @default("")
  descriptionText String?
  dueAt           DateTime
  status          TaskStatus    @default(TODO)
  priority        TaskPriority?
  assignedToId    String?
  createdById     String?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead       Lead?    @relation("LeadTasks", fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, leadId])
  @@index([businessId, status])
  @@index([businessId, assignedToId])
  @@index([businessId, dueAt])
  @@map("tasks")
}

model WorkItem {
  id            String         @id @default(uuid())
  businessId    String
  contactId     String
  serviceId     String?
  leadId        String?
  title         String
  type          String?
  status        WorkItemStatus @default(DRAFT)
  description   String?
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  amount        Decimal?       @db.Decimal(12, 2)
  assignedToId  String?
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Restrict)
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("WorkItemAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("WorkItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  estimates    Estimate[]
  invoices     Invoice[]
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, serviceId])
  @@index([businessId, status])
  @@index([businessId, assignedToId])
  @@index([businessId, scheduledAt])
  @@map("work_items")
}

model Estimate {
  id             String         @id @default(uuid())
  businessId     String
  contactId      String
  workItemId     String?
  estimateNumber String
  status         EstimateStatus @default(DRAFT)
  issueDate      DateTime
  expiryDate     DateTime?
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal        @default(0) @db.Decimal(12, 2)
  notes              String?
  termsAndConditions String?
  createdById        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  business  Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)
  workItem  WorkItem?      @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  createdBy User?          @relation("EstimateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     EstimateItem[]
  invoices  Invoice[]

  @@unique([businessId, estimateNumber])
  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, status])
  @@index([businessId, issueDate])
  @@map("estimates")
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String
  serviceId   String?
  title       String
  description String?
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([estimateId])
  @@map("estimate_items")
}

model Invoice {
  id            String        @id @default(uuid())
  businessId    String
  contactId     String
  estimateId    String?
  workItemId    String?
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime
  dueDate       DateTime?
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue         Decimal       @default(0) @db.Decimal(12, 2)
  publicToken            String        @unique
  publicUrl              String?
  paymentStatus          InvoicePaymentStatus @default(UNPAID)
  paidAmount             Decimal       @default(0) @db.Decimal(12, 2)
  remainingAmount        Decimal       @default(0) @db.Decimal(12, 2)
  lastPaymentAt          DateTime?
  stripeCheckoutUrl      String?
  stripePaymentLinkId    String?
  notes              String?
  paymentTerms       String?
  termsAndConditions String?
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  business  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contact   Contact       @relation(fields: [contactId], references: [id], onDelete: Restrict)
  estimate  Estimate?     @relation(fields: [estimateId], references: [id], onDelete: SetNull)
  workItem  WorkItem?     @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     InvoiceItem[]
  payments  Payment[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([businessId, contactId])
  @@index([businessId, estimateId])
  @@index([businessId, status])
  @@index([businessId, issueDate])
  @@index([publicToken])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  serviceId   String?
  title       String
  description String?
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id          String        @id @default(uuid())
  businessId  String
  invoiceId   String
  contactId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  provider              PaymentProvider @default(MANUAL)
  providerMetadata      Json?
  stripePaymentIntentId String?
  stripeCheckoutSessionId String? @unique
  stripeChargeId        String?
  stripeRefundId        String?
  reference   String?
  notes       String?
  paidAt      DateTime
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, invoiceId])
  @@index([businessId, contactId])
  @@index([businessId, method])
  @@index([businessId, paidAt])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model PlanGroup {
