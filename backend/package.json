{
  "name": "backend",
  "version": "0.0.1",
  "description": "Scalable NestJS monorepo with PostgreSQL, Prisma, Redis, and BullMQ",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api && nest build worker && nest build scheduler",
    "build:all": "nest build api && nest build worker && nest build scheduler",
    "format": "prettier --write \"{apps,libs}/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start api",
    "start:api": "nest start api",
    "start:worker": "nest start worker",
    "start:scheduler": "nest start scheduler",
    "start:dev": "nest start api --watch",
    "start:dev:api": "nest start api --watch",
    "start:dev:worker": "nest start worker --watch",
    "start:dev:scheduler": "nest start scheduler --watch",
    "dev:all": "concurrently -n api,worker -c blue,green \"nest start api --watch\" \"nest start worker --watch\"",
    "start:debug": "nest start api --debug --watch",
    "start:prod": "node dist/apps/api/main.js",
    "start:prod:api": "node dist/apps/api/main.js",
    "start:prod:worker": "node dist/apps/worker/main.js",
    "start:prod:scheduler": "node dist/apps/scheduler/main.js",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "bootstrap:whatsapp": "ts-node -r tsconfig-paths/register scripts/bootstrap-whatsapp-dev.ts",
    "openapi:export": "WRITE_OPENAPI=true nest start api",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@bull-board/api": "^6.7.0",
    "@bull-board/express": "^6.7.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.40.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv-expand": "^13.0.0",
    "ioredis": "^5.5.0",
    "joi": "^18.2.1",
    "luxon": "^3.7.2",
    "nestjs-pino": "^4.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "stripe": "^22.2.0",
    "svix": "^1.95.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^7.0.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "libs",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/common/(.*)$": "<rootDir>/common/$1",
      "^@app/core/(.*)$": "<rootDir>/core/$1",
      "^@app/modules/(.*)$": "<rootDir>/modules/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "passWithNoTests": true
  }
}
