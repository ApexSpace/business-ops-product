{
  "name": "business-automation",
  "private": true,
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "dev": "concurrently -n backend,web -c blue,magenta \"npm run dev:backend\" \"wait-on tcp:3000 && npm run dev:frontend\"",
    "dev:mobile": "npm run start --prefix mobile",
    "dev:mobile:ios": "npm run ios --prefix mobile",
    "dev:mobile:android": "npm run android --prefix mobile",
    "dev:backend": "concurrently -n api,worker -c blue,green \"npm run start:dev:api --prefix backend\" \"npm run start:dev:worker --prefix backend\"",
    "dev:api": "npm run start:dev:api --prefix backend",
    "dev:worker": "npm run start:dev:worker --prefix backend",
    "dev:scheduler": "npm run start:dev:scheduler --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:frontend:clean": "npm run dev:clean --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1"
  }
}
